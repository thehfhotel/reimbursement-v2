# ===========================================
# Environment Variables for Reimbursement App
# ===========================================
# Copy to .env for local dev (the API loads from this).

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/reimbursement

# API server
API_PORT=3001
UPLOADS_DIR=./apps/api/uploads

# Frontend
WEB_PORT=5173

# Auth
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production-please
JWT_EXPIRY_HOURS=24

# LINE OAuth (shared channel with fingerprint-time-logger)
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
# Where the LINE callback lands. Must be registered in LINE Developers console.
LINE_REDIRECT_URI=http://localhost:5173/auth/line/callback

# Where to redirect after auth (frontend base URL)
WEB_BASE_URL=http://localhost:5173
